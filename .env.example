# OCR Benchmark — environment configuration
# Copy to `.env` and edit. Defaults are safe (corrector off).

# ── Post-processing (SymSpell + KBBI) ──────────────────────────────
# Master switch. Flip to `true` to enable spell correction on OCR output.
ENABLE_SYMSPELL_CORRECTION=false

# KBBI-based word segmentation: re-insert lost spaces in joined-up text.
# Opt-in only. Default off because KBBI doesn't contain Indonesian affixed
# forms (me-NG-, ber-AN, etc.) and naive segmentation splits compound words,
# which hurts WER even when CER improves. Enable if your OCR routinely drops
# spaces between root words.
ENABLE_WORD_SEGMENTATION=false

# SymSpell edit-distance budget. 1 = conservative, 2 = aggressive.
SYMSPELL_MAX_EDIT_DISTANCE=1

# KBBI dictionary size. 0 = load all 194k (recommended for desktop).
# Set to e.g. 30000 on edge devices with tight memory.
KBBI_TOP_N=0

# Path to KBBI CSV (relative to repo root or absolute).
KBBI_CSV_PATH=kbbi/kbbi_v6.1.0_full.csv

# ── Benchmark ─────────────────────────────────────────────────────
# IoU threshold for matching predicted vs GT polygons (0.0 - 1.0).
IOU_THRESHOLD=0.5

# Image preprocessing (grayscale + CLAHE + 2x upscale for small images).
# Helps detect faint / low-contrast / small text. Off by default to mirror
# the raw ai4db backend; turn on if a category has many missed lines.
ENABLE_PREPROCESSING=false
PREPROC_UPSCALE_MIN_SIDE=800

# ── Server ────────────────────────────────────────────────────────
# `ocr-bench-serve` listens here. Change if 8765 is already in use.
SERVE_HOST=127.0.0.1
SERVE_PORT=8765

# ── OCR Model ──────────────────────────────────────────────────────
# PP-OCRv4 / PP-OCRv5 / PP-OCRv6
OCR_VERSION=PP-OCRv6
# v6: tiny / small / medium  |  v4/v5: mobile / server
MODEL_TYPE=small